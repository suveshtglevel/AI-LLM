# ============================================================
# Server
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database & Queue
# ============================================================
MONGODB_URI="mongodb://localhost:27017/ai-research-employee"
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# JWT
# ============================================================
JWT_SECRET=dev-jwt-secret-key-not-for-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-not-for-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# Default AI Provider (one of: openai, gemini, groq, openrouter,
#   mistral, github, deepseek, huggingface, googlecloud, azure,
#   anthropic, langchain, ai21, perplexity)
# ============================================================
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# API KEYS — Single key per provider for env-based fallback.
#
# 🔁 KEY ROTATION (advanced):
#   The UI supports multiple API keys per provider with
#   automatic round-robin rotation.  Simply add more keys
#   via the "Add Provider" form in the web app (one per line).
#   The backend rotates through them (least-recently-used),
#   tracks failures, and deactivates dead keys.
#
#   For 3–4 accounts per AI provider, create one provider
#   config in the UI and paste all 3–4 keys into the
#   "API Keys" field like this:
#
#     sk-abc123...
#     sk-def456...
#     sk-ghi789...
#
#   No .env changes needed — rotation is handled entirely
#   through the database and web UI.
# ============================================================

# OpenAI — 100k free tokens/day, resets every 60 min
#   In UI: paste 3–4 keys one per line under that provider config
#     sk-key1...
#     sk-key2...
#     sk-key3...
OPENAI_API_KEY=sk-placeholder

# Gemini — free tier available via Google AI Studio
#   In UI: paste 3–4 keys one per line under that provider config
#     ai-key1...
#     ai-key2...
#     ai-key3...
GEMINI_API_KEY=

# Groq — free tier available
#   In UI: paste 3–4 keys one per line under that provider config
#     gsk_key1...
#     gsk_key2...
#     gsk_key3...
GROQ_API_KEY=

# OpenRouter — aggregates many models with free limits
#   In UI: paste 3–4 keys one per line under that provider config
#     sk-or-key1...
#     sk-or-key2...
#     sk-or-key3...
OPENROUTER_API_KEY=

# Mistral AI — limited free tier (1k tokens/day)
#   In UI: paste 3–4 keys one per line under that provider config
#     mist-key1...
#     mist-key2...
#     mist-key3...
MISTRAL_API_KEY=

# GitHub Models — free with GitHub account
#   In UI: paste 3–4 keys one per line under that provider config
#     gh-key1...
#     gh-key2...
#     gh-key3...
GITHUB_MODELS_API_KEY=

# DeepSeek — 100k free tokens/day, resets every 60 min
#   In UI: paste 3–4 keys one per line under that provider config
#     sk-key1...
#     sk-key2...
#     sk-key3...
DEEPSEEK_API_KEY=

# Hugging Face — 100k free tokens/day, resets every 60 min
#   In UI: paste 3–4 keys one per line under that provider config
#     hf_key1...
#     hf_key2...
#     hf_key3...
HUGGINGFACE_API_KEY=

# Google Cloud AI Platform — $300 free credit (expires 90 days)
#   In UI: paste 3–4 keys one per line under that provider config
#     gcp-key1...
#     gcp-key2...
#     gcp-key3...
GOOGLECLOUD_API_KEY=

# Microsoft Azure — $200 free credit (expires 30 days)
#   In UI: paste 3–4 keys one per line under that provider config
#     az-key1...
#     az-key2...
#     az-key3...
AZURE_API_KEY=

# Anthropic Claude — 10k free tokens/month
#   In UI: paste 3–4 keys one per line under that provider config
#     sk-ant-key1...
#     sk-ant-key2...
#     sk-ant-key3...
ANTHROPIC_API_KEY=

# LangChain (LLaMA) — 20k free tokens/day, resets every 4 hours
#   In UI: paste 3–4 keys one per line under that provider config
#     lc-key1...
#     lc-key2...
#     lc-key3...
LANGCHAIN_API_KEY=

# AI21 Labs (Jurassic) — 50k free tokens/month
#   In UI: paste 3–4 keys one per line under that provider config
#     j21-key1...
#     j21-key2...
#     j21-key3...
AI21_API_KEY=

# Perplexity AI — unlimited personal use
#   In UI: paste 3–4 keys one per line under that provider config
#     pplx-key1...
#     pplx-key2...
#     pplx-key3...
PERPLEXITY_API_KEY=
