# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI="mongodb://localhost:27017/ai-research-employee"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=dev-jwt-secret-key-not-for-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-not-for-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
